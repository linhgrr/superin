# ─── Database ───────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=superin

# ─── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret-at-least-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS (JSON array) ─────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","https://your-app.vercel.app"]
ADMIN_EMAILS=[]

# ─── Deployment ────────────────────────────────────────────────────────────
HF_SPACE=false
SUBSCRIPTION_EXPIRY_CRON_ENABLED=true
SUBSCRIPTION_EXPIRY_CRON_TIMEZONE=Asia/Ho_Chi_Minh
SUBSCRIPTION_EXPIRY_CRON_HOUR=0
SUBSCRIPTION_EXPIRY_CRON_MINUTE=0
SUBSCRIPTION_EXPIRY_CRON_BATCH_LIMIT=500

# ─── Redis (required for multi-worker rate limiting) ───────────────────────
# Leave empty to use in-memory rate limiting (single-worker only)
# REDIS_URL=redis://localhost:6379/0

# ─── AI (OpenAI-compatible) ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
LLM_REQUEST_TIMEOUT_SECONDS=60
# Total timeout for a delegated child-agent run (model + tools + result shaping)
CHILD_AGENT_TIMEOUT_SECONDS=60
# Supervisor guardrails for root multi-round dispatch
ROOT_AGENT_MAX_DISPATCH_ROUNDS=3
ROOT_AGENT_MAX_APP_ATTEMPTS_PER_TURN=2
LLM_STREAM_IDLE_TIMEOUT_SECONDS=90
MEMORY_SEMANTIC_SEARCH_ENABLED=false
# Optional: enable semantic memory search with a dedicated embedding model.
# When enabled, MongoDBStore will create/use a vector index for memory recall.
MEMORY_EMBEDDING_MODEL=text-embedding-3-small
MEMORY_EMBEDDING_DIMENSIONS=1536
MEMORY_VECTOR_INDEX_NAME=superin_memory_index

# ─── Object Storage (S3-compatible, path-style) ─────────────────────────────
OBJECT_STORAGE_ACCESS_KEY=...
OBJECT_STORAGE_SECRET_KEY=...
OBJECT_STORAGE_BUCKET=xfwyb01b-superin
OBJECT_STORAGE_REGION=ap-southeast-1
OBJECT_STORAGE_ENDPOINT_INTERNAL=object-storage.objectstorage-system.svc.cluster.local
OBJECT_STORAGE_ENDPOINT_EXTERNAL=objectstorageapi.ap-southeast-1.clawcloudrun.com
OBJECT_STORAGE_ADDRESSING_STYLE=path
OBJECT_STORAGE_AVATAR_MAX_BYTES=5242880
OBJECT_STORAGE_AVATAR_PREFIX=avatars

# ─── Payments ───────────────────────────────────────────────────────────────
PAYMENT_DEFAULT_PROVIDER=stripe

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
STRIPE_PRICE_ID_PAID_MONTHLY=price_...
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5173/billing/success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5173/billing/cancel

# PayOS
PAYOS_CLIENT_ID=...
PAYOS_API_KEY=...
PAYOS_CHECKSUM_KEY=...
PAYOS_BASE_URL=https://api-merchant.payos.vn
PAYOS_RETURN_URL=http://localhost:5173/billing/success
PAYOS_CANCEL_URL=http://localhost:5173/billing/cancel
PAYOS_AMOUNT_VND=99000
PAYOS_PAID_DURATION_DAYS=30
PAYOS_PAYMENT_LINK_EXPIRE_SECONDS=1800
